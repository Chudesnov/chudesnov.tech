<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ (title + " — ") if title }}Sasha Chudesnov</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  {% if site.showNav %}
  <header>
    <nav>
      <a href="/" {% if page.url == "/" %}aria-current="page"{% endif %}>Home</a>
      <a href="/writing/" {% if "/writing/" in page.url %}aria-current="page"{% endif %}>Writing</a>
    </nav>
  </header>
  {% endif %}
  <main>
    {{ content | safe }}
  </main>
</body>
</html>
