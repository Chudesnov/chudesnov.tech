<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ (title + " — ") if title }}Sasha Chudesnov</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  {% if site.showNav %}
  <header>
    <nav>
      {% if page.url == "/" %}<span aria-current="page">Home</span>{% else %}<a href="/">Home</a>{% endif %}
      {% if "/writing/" in page.url %}<span aria-current="page">Writing</span>{% else %}<a href="/writing/">Writing</a>{% endif %}
    </nav>
  </header>
  {% endif %}
  <main>
    {{ content | safe }}
  </main>
</body>
</html>
