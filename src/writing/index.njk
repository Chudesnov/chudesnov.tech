---
layout: base.njk
title: Writing
---
<h1>Writing</h1>
{% if collections.writing.length %}
<ul>
  {% for post in collections.writing %}
  <li>
    <a href="{{ post.url }}">{{ post.data.title }}</a>
    <time datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate }}</time>
  </li>
  {% endfor %}
</ul>
{% else %}
<p>No posts yet.</p>
{% endif %}
